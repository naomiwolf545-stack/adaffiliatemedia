# MongoDB connection string (from MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/adaffiliate

# JWT secret key — change this to a long random string!
JWT_SECRET=change_this_to_a_very_long_random_secret_key_12345

# First admin account credentials (used by /api/seed)
ADMIN_EMAIL=admin@adaffiliate.com
ADMIN_PASS=Admin@1234

# Server port
PORT=5000
